  "keyFeatures": [
    "Exact and approximate nearest neighbor search for dense float vectors",
    "Inverted file (IVF) indexes for scalable billion-scale search",
    "Product quantization (PQ) and scalar quantization for compressed storage",
    "HNSW and NSG graph-based indexes for fast approximate search",
    "GPU-accelerated indexes (CUDA) for maximum throughput",
    "K-means clustering with CPU and GPU support",
    "Index factory string API for declarative index construction",
    "Auto-tuning framework for optimizing search parameters",
    "Python/NumPy bindings with full C++ API parity",
    "On-disk and distributed index support via contrib modules"
  ],
  "publicApiSurface": [
